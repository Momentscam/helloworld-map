# Copy this file to `.env` for local dev, and set the same vars in
# Vercel → Project → Settings → Environment Variables for production.

# Google Apps Script Web App URL that receives "Request a New Bottle" submissions
# and appends them to the Google Sheet. See scripts/google-apps-script.gs for setup.
VITE_SHEETS_ENDPOINT=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec

# PostHog analytics — "Project API Key" from the Atlas project's settings.
# The phc_ key is a public client key (safe to ship), not a secret.
VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Ingestion host — EU cloud by default; use https://us.i.posthog.com for US.
VITE_POSTHOG_HOST=https://eu.i.posthog.com
